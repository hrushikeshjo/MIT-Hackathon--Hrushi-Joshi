# Copy this file to .env for local configuration.
# Do not commit .env; it is already ignored by .gitignore.

# Core app mode: auto | local | llm
DISASTER_MAS_MODE=auto

# Official structured web data. No keys required for NWS, USGS, or FEMA.
ENABLE_OFFICIAL_WEB_DATA=true
WEB_TIMEOUT_SECONDS=3

# Optional general web search.
ENABLE_WEB_SEARCH=false
TAVILY_API_KEY=

# Optional Anthropic LLM/web-search support.
ANTHROPIC_API_KEY=
